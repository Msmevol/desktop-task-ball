{
  "name": "desktop-task-ball",
  "version": "0.1.0",
  "private": true,
  "description": "桌面 AI 辅助 Python 任务小球",
  "main": "./out/main/index.js",
  "author": "you",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "script-server:start": "python script-server/start.py",
    "script-server:start:node": "node script-server/server.js",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run"
  },
  "dependencies": {
    "nanoid": "^3.3.8",
    "sql.js": "^1.11.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.0.2",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.45",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vitest": "^2.1.9"
  }
}
